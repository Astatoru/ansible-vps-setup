#!/bin/bash
# vim:ft=bash
declare -a DEPENDENCIES="(ipset wget)"

# Function that displays error messages
function error() {
  local MESSAGE="$1"
  # Check if stderr is in interactive mode
  if [[ -t 2 ]]; then
    >&2 printf "%b\n" "\033[01;31mERROR\033[0m: $MESSAGE"
  else
    >&2 printf "%s\n" "ERROR: $MESSAGE"
  fi
}

# Function that displays info messages
function info() {
  local MESSAGE="$1"
  # Check if stdout is in interactive mode
  if [[ -t 1 ]]; then
    printf "%b\n" "\033[01;34mINFO\033[0m: $MESSAGE"
  else
    printf "%s\n" "INFO: $MESSAGE"
  fi
}

# Check if the script is run as root
function checkRoot() {
  if ((EUID != 0)); then
    error "Please run this script as root"
    exit 1
  fi
}

# Check if dependencies are installed
function checkDependencies() {
  for CMD in "${DEPENDENCIES[@]}"; do
    if ! command -v "$CMD" &>/dev/null; then
      error "$CMD is not installed"
      exit 1
    fi
  done
}

# Update ipset lists
function updateLists() {
  wget -4 \
    "https://raw.githubusercontent.com/C24Be/AS_Network_List/refs/heads/main/blacklists_iptables/blacklist-v4.ipset" \
    --output-document "/etc/blacklist-v4.ipset" \
    -q \
    --show-progress
  wget -4 \
    "https://raw.githubusercontent.com/C24Be/AS_Network_List/refs/heads/main/blacklists_iptables/blacklist-v6.ipset" \
    --output-document "/etc/blacklist-v6.ipset" \
    -q \
    --show-progress
}

# Create new ipset lists
function addLists() {
  set +o "errexit"
  ipset destroy blacklist-v4 &>/dev/null
  ipset destroy blacklist-v6 &>/dev/null
  set -o "errexit"
  ipset restore -file "/etc/blacklist-v4.ipset"
  ipset restore -file "/etc/blacklist-v6.ipset"
  info "Blacklists were successfully updated"
}

# Main function
function main() {
  checkRoot
  checkDependencies
  updateLists
}

# Stop script execution immediately
# If any command below fails
set -o "errexit"
# Throw an error if script fails
trap "error 'Something went wrong...'; exit 1" EXIT

# Execute main function
main "$@"

# Disable trap
trap "" EXIT
